{
  "name": "gitwatch",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli",
    "migrate:up": "cd src/infra/database && kysely migrate:up",
    "migrate:down": "cd src/infra/database && kysely migrate:down",
    "migrate:list": "cd src/infra/database && kysely migrate:list",
    "migrate:make": "cd src/infra/database && kysely migrate:make",
    "migrate:redo": "cd src/infra/database && kysely migrate:redo",
    "migrate:reset": "cd src/infra/database && kysely migrate:reset",
    "migrate:init": "cd src/infra/database && kysely migrate:init",
    "migrate:build": "cd src/infra/database && kysely migrate:build",
    "migrate:up:step": "cd src/infra/database && kysely migrate:up --step",
    "migrate:down:step": "cd src/infra/database && kysely migrate:down --step",
    "db:codegen": "kysely-codegen --dialect postgres --out-file src/infra/database/database.types.ts --exclude-pattern migrations --exclude-pattern audit_  --exclude-pattern flyway_",
    "seed": "kysely seed run",
    "seed:all": "kysely seed run --all",
    "gen": "bash src/common/generators/generate.sh all",
    "gen:controller": "bash src/common/generators/generate.sh controller",
    "gen:service": "bash src/common/generators/generate.sh service",
    "gen:facade": "bash src/common/generators/generate.sh facade",
    "gen:repository": "bash src/common/generators/generate.sh repository",
    "gen:dtos": "bash src/common/generators/generate.sh dtos",
    "gen:events": "bash src/common/generators/generate.sh events",
    "gen:module": "bash src/common/generators/generate.sh module"
  },
  "dependencies": {
    "@mikro-orm/core": "^6.6.1",
    "@mikro-orm/nestjs": "^6.1.1",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "*",
    "@nestjs/platform-express": "^11.0.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "dotenv": "^17.2.3",
    "joi": "^18.0.2",
    "kysely": "^0.28.8",
    "nestjs-kysely": "^3.1.2",
    "nodemailer": "^7.0.11",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "pug": "^3.0.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@faker-js/faker": "^10.1.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.1",
    "@types/nodemailer": "^7.0.4",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "install": "^0.13.0",
    "jest": "^30.0.0",
    "kysely-codegen": "^0.19.0",
    "kysely-ctl": "^0.19.0",
    "kysely-migration-cli": "^0.4.2",
    "npm": "^11.7.0",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "prettier": "^3.7.4",
    "prettier-plugin-sort-imports": "^1.8.9",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
